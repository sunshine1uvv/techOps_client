<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="25" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.tech_ops_gui.controllers.admin.DirectoriesViewController">
    <padding>
        <Insets bottom="30" left="30" right="30" top="30" />
    </padding>

    <Label style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #2C3E50;" text="Управление справочниками" />

    <HBox spacing="30">
        <VBox maxWidth="350" spacing="15" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 15, 0, 0, 5);" HBox.hgrow="ALWAYS">
            <Label style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #34495E;" text="Типы оборудования" />
            <Label style="-fx-text-fill: #7F8C8D; -fx-font-size: 13;" text="Добавление новых типов с учетом иерархии (1-6 уровни) или удаление существующих из базы данных." wrapText="true" />

            <Region VBox.vgrow="ALWAYS" />

            <VBox spacing="10">
                <Button maxWidth="Infinity" onAction="#handleAddType" style="-fx-background-color: #2ECC71; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10; -fx-cursor: hand; -fx-background-radius: 6;" text="+ Добавить тип" />
                <Button maxWidth="Infinity" onAction="#handleDeleteType" style="-fx-background-color: #E74C3C; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10; -fx-cursor: hand; -fx-background-radius: 6;" text="– Удалить тип" />
            </VBox>
        </VBox>

        <VBox maxWidth="350" spacing="15" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 12; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 15, 0, 0, 5);" HBox.hgrow="ALWAYS">
            <Label style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #34495E;" text="Подразделения" />
            <Label style="-fx-text-fill: #7F8C8D; -fx-font-size: 13;" text="Управление организационной структурой: добавление новых отделов и удаление неактуальных." wrapText="true" />

            <Region VBox.vgrow="ALWAYS" />

            <VBox spacing="10">
                <Button maxWidth="Infinity" onAction="#handleAddDepartment" style="-fx-background-color: #3498DB; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10; -fx-cursor: hand; -fx-background-radius: 6;" text="+ Добавить подразделение" />
                <Button maxWidth="Infinity" onAction="#handleDeleteDepartment" style="-fx-background-color: #E74C3C; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10; -fx-cursor: hand; -fx-background-radius: 6;" text="– Удалить подразделение" />
            </VBox>
        </VBox>
    </HBox>
</VBox>