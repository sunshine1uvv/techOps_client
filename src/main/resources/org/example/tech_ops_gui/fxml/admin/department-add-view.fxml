<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox prefWidth="850" prefHeight="500" spacing="0" styleClass="management-container"
      stylesheets="@../../css/auth/common.css, @../../css/crud/department-management.css"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.tech_ops_gui.controllers.admin.DepartmentAddViewController">

    <VBox spacing="10" HBox.hgrow="ALWAYS" styleClass="left-panel">
        <Label styleClass="header-label" text="Текущие подразделения" />
        <TableView fx:id="departmentTable" VBox.vgrow="ALWAYS" styleClass="modern-table">
            <columns>
                <TableColumn fx:id="nameCol" prefWidth="150" text="Название" />
                <TableColumn fx:id="descCol" prefWidth="200" text="Описание" />
            </columns>
            <columnResizePolicy>
                <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
            </columnResizePolicy>
        </TableView>
    </VBox>

    <VBox prefWidth="400" minWidth="400" spacing="20" styleClass="right-panel">
        <VBox spacing="5">
            <Label styleClass="header-label" text="Новое подразделение" />
            <Label styleClass="subheader-label" text="Добавьте новую структурную единицу организации" />
        </VBox>

        <Separator />

        <VBox spacing="15" VBox.vgrow="ALWAYS">
            <VBox spacing="5">
                <Label styleClass="form-label" text="Название подразделения *" />
                <TextField fx:id="nameField" promptText="Например: Отдел ИТ" styleClass="modern-text-field" />
            </VBox>

            <VBox spacing="5">
                <Label styleClass="form-label" text="Описание / Примечание" />
                <TextArea fx:id="descriptionArea" prefHeight="100" promptText="Укажите назначение подразделения..." styleClass="modern-text-area" wrapText="true" />
            </VBox>
        </VBox>

        <Separator />

        <HBox alignment="CENTER_RIGHT" spacing="15">
            <Button onAction="#handleCancel" style="-fx-background-color: transparent; -fx-border-color: #BDC3C7; -fx-border-radius: 4; -fx-text-fill: #7F8C8D; -fx-font-weight: bold; -fx-padding: 8 20; -fx-cursor: hand;" text="Отмена" />
            <Button onAction="#handleSave" style="-fx-background-color: #2ECC71; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 20; -fx-background-radius: 4; -fx-cursor: hand;" text="Сохранить" />
        </HBox>
    </VBox>
</HBox>