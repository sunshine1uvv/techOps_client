<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.ComboBox?>
<VBox spacing="15" style="-fx-background-color: white;" stylesheets="@../../css/auth/common.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.tech_ops_gui.controllers.admin.RegistrationRequestsController">
    <padding>
        <Insets bottom="20" left="20" right="20" top="20" />
    </padding>

    <Label style="-fx-font-size: 22px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;" text="Заявки на регистрацию" />

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Label text="Статус заявок:" />
        <ComboBox fx:id="filterComboBox" prefWidth="185"
                  prefHeight="45" minHeight="45" maxHeight="45"
                  styleClass="modern-combo-box"/>
    </HBox>

    <TableView fx:id="requestsTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colUsername" prefWidth="120" text="Логин" />
            <TableColumn fx:id="colName" prefWidth="100" text="Имя" />
            <TableColumn fx:id="colSurname" prefWidth="100" text="Фамилия" />
            <TableColumn fx:id="colRank" prefWidth="120" text="Звание" />
            <TableColumn fx:id="colPhone" prefWidth="120" text="Телефон" />
            <TableColumn fx:id="colStatus" prefWidth="100" text="Статус" />
        </columns>
        <placeholder>
            <Label text="Запросы по заданному фильтру не найдены"/>
        </placeholder>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <HBox alignment="CENTER_RIGHT" spacing="10">
        <Button onAction="#refreshRequests" styleClass="btn-secondary" text="Обновить" />
        <Button onAction="#restoreRequest" styleClass="btn-secondary" text="Восстановить" />
        <Button onAction="#approveRequest" styleClass="btn-primary" text="Одобрить" />
        <Button onAction="#rejectRequest" styleClass="btn-danger" text="Отклонить" />
    </HBox>
</VBox>
