<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" alignment="TOP_CENTER" prefWidth="550" prefHeight="450"
      style="-fx-background-color: white; -fx-background-radius: 15; -fx-border-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 0);"
      stylesheets="@../../css/auth/common.css"
      xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.tech_ops_gui.controllers.crud.HoursHistoryViewController">

    <padding>
        <Insets top="25" right="25" bottom="25" left="25"/>
    </padding>

    <VBox spacing="5" alignment="CENTER">
        <Label text="История наработок" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #2C3E50;"/>
        <Label fx:id="typeLabel" style="-fx-text-fill: #34495E; -fx-font-size: 14px; -fx-font-weight: bold;"/>
        <Label fx:id="nameLabel" style="-fx-text-fill: #5D6D7E; -fx-font-size: 13px; -fx-font-weight: bold;"/>
        <Label fx:id="invLabel" style="-fx-text-fill: #95A5A6; -fx-font-size: 12px; -fx-font-style: italic;"/>
    </VBox>

    <TableView fx:id="historyTable" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="dateCol" text="Дата и время" prefWidth="140"/>
            <TableColumn fx:id="userCol" text="Пользователь" prefWidth="230"/>
            <TableColumn fx:id="hoursCol" text="Добавлено (ч)" prefWidth="120"/>
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
        </columnResizePolicy>
        <placeholder>
            <Label text="История наработок пуста"/>
        </placeholder>
    </TableView>

</VBox>