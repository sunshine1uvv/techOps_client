<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="org.example.tech_ops_gui.controllers.admin.UserManagementController"
      stylesheets="@../../css/users/users.css"
      spacing="10" style="-fx-padding: 20; -fx-background-color: #f0f2f5;">

    <ScrollPane fitToWidth="true" hbarPolicy="NEVER" VBox.vgrow="ALWAYS"
                style="-fx-background-color: transparent;">
        <TilePane fx:id="userCardsContainer" hgap="15" vgap="15"
                  style="-fx-padding: 5; -fx-background-color: transparent;"
                  tileAlignment="TOP_LEFT"/>
    </ScrollPane>
</VBox>