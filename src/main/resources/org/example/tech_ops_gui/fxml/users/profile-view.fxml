<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<TabPane fx:id="profileTabPane"
         xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
         fx:controller="org.example.tech_ops_gui.controllers.ProfileController"
         stylesheets="@../../css/users/profile.css"
         styleClass="profile-tab-pane"
         tabClosingPolicy="UNAVAILABLE">

    <!-- Вкладка 1: Личные данные -->
    <Tab text="Профиль">
        <content>
            <AnchorPane styleClass="profile-content">
                <VBox spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                      AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                    <padding>
                        <Insets bottom="20.0" left="30.0" right="30.0" top="20.0"/>
                    </padding>

                    <!-- Аватар и ФИО -->
                    <HBox alignment="CENTER_LEFT" spacing="20.0">
                        <ImageView fx:id="avatarImageView" fitHeight="80.0" fitWidth="80.0"
                                   pickOnBounds="true" preserveRatio="true" styleClass="avatar"/>
                        <VBox spacing="5.0">
                            <Label fx:id="fullNameLabel" styleClass="full-name-label"
                                   text="Фамилия Имя Отчество">
                                <font>
                                    <Font name="System Bold" size="24.0"/>
                                </font>
                            </Label>
                            <Label fx:id="roleLabel" styleClass="role-label" text="Роль"/>
                        </VBox>
                    </HBox>

                    <Separator/>

                    <!-- Детальная информация -->
                    <GridPane hgap="15.0" vgap="10.0" styleClass="info-grid">
                        <columnConstraints>
                            <ColumnConstraints hgrow="NEVER" minWidth="120.0"/>
                            <ColumnConstraints hgrow="SOMETIMES" minWidth="200.0"/>
                        </columnConstraints>

                        <Label text="Логин:" styleClass="field-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                        <Label fx:id="usernameLabel" text="username" styleClass="field-value"
                               GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                        <Label text="Звание:" styleClass="field-label" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                        <Label fx:id="rankLabel" text="звание" styleClass="field-value"
                               GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                        <Label text="Телефон:" styleClass="field-label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                        <Label fx:id="phoneLabel" text="+7 (XXX) XXX-XX-XX" styleClass="field-value"
                               GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                        <Label text="Статус:" styleClass="field-label" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                        <Label fx:id="statusLabel" text="Активен" styleClass="field-value"
                               GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                        <Label text="Зарегистрирован:" styleClass="field-label" GridPane.rowIndex="4"
                               GridPane.columnIndex="0"/>
                        <Label fx:id="createdAtLabel" text="01.01.2023 12:00" styleClass="field-value"
                               GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                    </GridPane>
                </VBox>
            </AnchorPane>
        </content>
    </Tab>

    <!-- Вкладка 2: Закреплённое оборудование -->
    <Tab text="Оборудование">
        <content>
            <AnchorPane styleClass="profile-content">
                <VBox spacing="10.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0"
                      AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                    <padding>
                        <Insets bottom="20.0" left="30.0" right="30.0" top="20.0"/>
                    </padding>
                    <Label styleClass="section-title" text="Закреплённое за вами оборудование">
                        <font>
                            <Font name="System Bold" size="18.0"/>
                        </font>
                    </Label>
                    <TableView fx:id="equipmentTable" VBox.vgrow="ALWAYS">
                        <columnResizePolicy>
                            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                        </columnResizePolicy>
                        <columns>
                            <TableColumn fx:id="invNumCol" text="Инв. №"/>
                            <TableColumn fx:id="serialNumCol" text="Серийный №"/>
                            <TableColumn fx:id="typeCol" text="Тип"/>
                            <TableColumn fx:id="nameCol" text="Наименование"/>
                            <TableColumn fx:id="locationCol" text="Локация"/>
                            <TableColumn fx:id="categoryCol" text="Категория"/>
                            <TableColumn fx:id="isBundledCol" text="В комплекте"/>
                            <TableColumn fx:id="fullCodeCol" text="Код номенклатуры"/>
                        </columns>
                        <placeholder>
                            <Label text="Нет закреплённого оборудования"/>
                        </placeholder>
                    </TableView>
                </VBox>
            </AnchorPane>
        </content>
    </Tab>
</TabPane>