<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<BorderPane fx:id="rootPane" prefHeight="600.0" prefWidth="800.0" xmlns="http://javafx.com" xmlns:fx="http://javafx.com"
            fx:controller="org.example.tech_ops_gui.controllers.MainController">
    <left>
        <VBox spacing="10" style="-fx-background-color: #D4D7D7; -fx-padding: 15;" prefWidth="180">
            <children>
                <Button onAction="#loadEquipmentView" styleClass="menu-button"
                        style="-fx-background-color: transparent; -fx-cursor: hand;">
                    <graphic>
                        <HBox spacing="10" alignment="CENTER">
                            <ImageView fitWidth="24.0" preserveRatio="true">
                                <image>
                                    <Image url="@../icons/accounting.png"/>
                                </image>
                            </ImageView>
                            <Label text="Учет" style="-fx-font-size: 14px;"/>
                        </HBox>
                    </graphic>
                </Button>
                <Button fx:id="registrationRequestsViewBtn" onAction="#loadRegistrationRequestView" styleClass="menu-button"
                        style="-fx-background-color: transparent; -fx-cursor: hand;">
                    <graphic>
                        <HBox spacing="10" alignment="CENTER">
                            <ImageView fitWidth="24.0" preserveRatio="true">
                                <image>
                                    <Image url="@../icons/registration-request-menu.png"/>
                                </image>
                            </ImageView>
                            <Label text="Заявки" style="-fx-font-size: 14px;"/>
                        </HBox>
                    </graphic>
                </Button>
                <Button fx:id="usersViewBtn" onAction="#loadUsersView" styleClass="menu-button"
                        style="-fx-background-color: transparent; -fx-cursor: hand;">
                    <graphic>
                        <HBox spacing="10" alignment="CENTER">
                            <ImageView fitWidth="24.0" preserveRatio="true">
                                <image>
                                    <Image url="@../icons/users.png"/>
                                </image>
                            </ImageView>
                            <Label text="Пользователи" style="-fx-font-size: 14px;"/>
                        </HBox>
                    </graphic>
                </Button>
                <Button fx:id="profileViewBtn" onAction="#loadProfileView" styleClass="menu-button"
                        style="-fx-background-color: transparent; -fx-cursor: hand;">
                    <graphic>
                        <HBox spacing="10" alignment="CENTER">
                            <ImageView fitWidth="24.0" preserveRatio="true">
                                <image>
                                    <Image url="@../icons/profile.png"/>
                                </image>
                            </ImageView>
                            <Label text="Мой профиль" style="-fx-font-size: 14px;"/>
                        </HBox>
                    </graphic>
                </Button>
                <Region VBox.vgrow="ALWAYS" />
                <Button onAction="#logout" styleClass="menu-button"
                        style="-fx-background-color: transparent; -fx-cursor: hand; -fx-text-fill: #d9534f;">
                    <graphic>
                        <HBox spacing="10" alignment="CENTER">
                            <ImageView fitWidth="24.0" preserveRatio="true">
                                <image>
                                    <Image url="@../icons/logout.png"/>
                                </image>
                            </ImageView>
                            <Label text="Выйти" style="-fx-font-size: 14px;"/>
                        </HBox>
                    </graphic>
                </Button>
            </children>
        </VBox>
    </left>
    <center>
        <StackPane fx:id="contentArea"/>
    </center>
</BorderPane>

