<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" prefWidth="800" prefHeight="500"
      style="-fx-background-color: white; -fx-background-radius: 10;"
      stylesheets="@../css/crud/equipment-add-view.css"
      xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.tech_ops_gui.controllers.crud.ConflictResolverController">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <VBox spacing="5">
        <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #E67E22;"
               text="Обнаружены дубликаты номеров"/>
        <Label style="-fx-text-fill: #7F8C8D;" wrapText="true"
               text="Следующие записи уже существуют в системе. Исправьте данные в таблице или исключите их из сохранения."/>
    </VBox>

    <TableView fx:id="conflictTable" VBox.vgrow="ALWAYS" editable="true" styleClass="modern-table">
        <columns>
            <TableColumn fx:id="skipCol" text="Пропустить" prefWidth="90" />
            <TableColumn fx:id="nameCol" text="Наименование" prefWidth="150" editable="false"/>
            <TableColumn fx:id="invCol" text="Инвентарный №" prefWidth="130"/>
            <TableColumn fx:id="serialCol" text="Серийный №" prefWidth="130"/>
            <TableColumn fx:id="reasonCol" text="Причина" prefWidth="150" editable="false"/>
        </columns>
    </TableView>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button text="🔳 Пропустить всё"
                onAction="#handleSelectAllSkip"
                styleClass="btn-secondary" />
        <Button text="🪄 Исправить автоматически"
                onAction="#handleAutoFix"
                styleClass="btn-info" />

        <Region HBox.hgrow="ALWAYS" />

        <Button text="Отмена"
                onAction="#handleCancel"
                styleClass="btn-secondary"/>
        <Button text="Принять и сохранить"
                onAction="#handleConfirm"
                styleClass="btn-primary"/>
    </HBox>
</VBox>